# ═══════════════════════════════════════════════════════════════════════════════
# ModelMesh — Environment Variables
# Copy this file to .env and fill in values before running locally.
# NEVER commit .env to git — it is in .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App Meta ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json                  # json (prod) | text (local dev)

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=modelmesh
POSTGRES_PASSWORD=modelmesh_secret
POSTGRES_DB=modelmesh_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_PREDICTION_TOPIC=modelmesh.predictions
KAFKA_DRIFT_ALERT_TOPIC=modelmesh.drift_alerts
KAFKA_RETRAIN_TRIGGER_TOPIC=modelmesh.retrain_triggers
KAFKA_CONSUMER_GROUP=modelmesh-consumers

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_REGISTRY_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=modelmesh-churn-detection
MLFLOW_MODEL_NAME=churn-classifier
# MLFLOW_S3_BUCKET=your-mlflow-artifacts-bucket   # uncomment for S3 artifacts

# ── Model Serving ─────────────────────────────────────────────────────────────
CHAMPION_MODEL_ALIAS=champion
CHALLENGER_MODEL_ALIAS=challenger
SHADOW_TRAFFIC_PCT=0.05          # 5% traffic to challenger
INFERENCE_TIMEOUT_SECS=2.0
MAX_BATCH_SIZE=128
ENABLE_SHAP=true
SHAP_SAMPLE_RATE=0.1             # SHAP on 10% of requests

# ── Monitoring ────────────────────────────────────────────────────────────────
DRIFT_CHECK_INTERVAL_MINUTES=60
DRIFT_REFERENCE_WINDOW=5000
DRIFT_CURRENT_WINDOW=1000
PSI_THRESHOLD=0.2
KS_P_VALUE_THRESHOLD=0.05
F1_DEGRADATION_THRESHOLD=0.02
PROMETHEUS_PORT=8001

# ── Retraining ────────────────────────────────────────────────────────────────
MIN_IMPROVEMENT_PCT=0.02         # challenger must beat champion by ≥2% F1
AUTO_PROMOTE=false               # set true to auto-promote in prod
RETRAIN_DEPLOYMENT_NAME=modelmesh-retrain/production
MAX_RETRAIN_PER_DAY=3

# ── Security ──────────────────────────────────────────────────────────────────
API_KEY_HEADER=X-API-Key
API_KEYS=dev-key-1234,test-key-5678   # comma-separated list
RATE_LIMIT_PER_MINUTE=1000
CORS_ORIGINS=http://localhost:3000

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_SHADOW_DEPLOYMENT=true
ENABLE_AUTO_RETRAIN=true
ENABLE_KAFKA_STREAMING=true
ENABLE_PROMETHEUS=true

# ── Prefect ───────────────────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api
